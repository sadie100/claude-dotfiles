+#!/usr/bin/env node
+// Regenerates auto-managed sections of HARNESS.md from settings.json,
+// local skills, and the Claude Code plugin cache.
+// Marker format in HARNESS.md: <!-- AUTO:BEGIN <id> --> ... <!-- AUTO:END <id> -->
+
+import { readFileSync, writeFileSync, readdirSync, statSync, existsSync } from "node:fs";
+import { homedir } from "node:os";
+import { dirname, join, resolve } from "node:path";
+import { fileURLToPath } from "node:url";
+
+const SCRIPT_DIR = dirname(fileURLToPath(import.meta.url));
+const REPO_ROOT = process.env.DOTCLAUDE_DIR
+  ? resolve(process.env.DOTCLAUDE_DIR)
+  : resolve(SCRIPT_DIR, "..", "..");
+const PLUGINS_ROOT = join(homedir(), ".claude", "plugins");
+const PLUGIN_CACHE = join(PLUGINS_ROOT, "cache");
+const MARKETPLACES_DIR = join(PLUGINS_ROOT, "marketplaces");
+const HARNESS_PATH = join(REPO_ROOT, "HARNESS.md");
+const SETTINGS_PATH = join(REPO_ROOT, "settings.json");
+const GLOBAL_CLAUDE_MD = join(homedir(), ".claude", "CLAUDE.md");
+
+// ---------- utilities ----------
+
+function readJsonSafe(path) {
+  try {
+    return JSON.parse(readFileSync(path, "utf8"));
+  } catch {
+    return null;
+  }
+}
+
+function readTextSafe(path) {
+  try {
+    return readFileSync(path, "utf8");
+  } catch {
+    return null;
+  }
+}
+
+function lsDirs(path) {
+  try {
+    return readdirSync(path, { withFileTypes: true })
+      .filter((d) => d.isDirectory())
+      .map((d) => d.name);
+  } catch {
+    return [];
+  }
+}
+
+function lsFiles(path) {
+  try {
+    return readdirSync(path, { withFileTypes: true })
+      .filter((d) => d.isFile())
+      .map((d) => d.name);
+  } catch {
+    return [];
+  }
+}
+
+function pickLatestVersionDir(parentDir) {
+  const subs = lsDirs(parentDir);
+  if (subs.length === 0) return null;
+  let best = null;
+  let bestMtime = -1;
+  for (const sub of subs) {
+    try {
+      const m = statSync(join(parentDir, sub)).mtimeMs;
+      if (m > bestMtime) {
+        bestMtime = m;
+        best = sub;
+      }
+    } catch {
+      /* ignore */
+    }
+  }
+  return best ? join(parentDir, best) : null;
+}
+
+// Minimal YAML frontmatter parser. Handles simple `key: value` lines and
+// block scalars (`key: >` folded / `key: |` literal) with indented continuations.
+function parseFrontmatter(content) {
+  if (!content) return {};
+  const m = content.match(/^---\r?\n([\s\S]*?)\r?\n---/);
+  if (!m) return {};
+  const fields = {};
+  const lines = m[1].split(/\r?\n/);
+  let i = 0;
+  while (i < lines.length) {
+    const line = lines[i];
+    const kv = line.match(/^([A-Za-z][\w-]*)\s*:\s*(.*)$/);
+    if (!kv) {
+      i++;
+      continue;
+    }
+    const key = kv[1];
+    let val = kv[2].trim();
+    if (val === ">" || val === "|" || val === ">-" || val === "|-") {
+      const literal = val.startsWith("|");
+      const parts = [];
+      i++;
+      while (i < lines.length) {
+        const next = lines[i];
+        if (/^\S/.test(next)) break; // dedented = end of block
+        parts.push(next.replace(/^\s+/, ""));
+        i++;
+      }
+      val = literal ? parts.join("\n").trim() : parts.join(" ").trim();
+    } else {
+      if ((val.startsWith('"') && val.endsWith('"')) || (val.startsWith("'") && val.endsWith("'"))) {
+        val = val.slice(1, -1);
+      }
+      i++;
+    }
+    fields[key] = val;
+  }
+  return fields;
+}
+
+function escapeCell(s) {
+  if (s == null) return "";
+  return String(s).replace(/\r?\n/g, " ").replace(/\|/g, "\\|").trim();
+}
+
+function renderTable(headers, rows) {
+  if (rows.length === 0) {
+    return `_(none)_`;
+  }
+  const head = `| ${headers.join(" | ")} |`;
+  const sep = `|${headers.map(() => "---").join("|")}|`;
+  const body = rows.map((r) => `| ${r.map(escapeCell).join(" | ")} |`).join("\n");
+  return `${head}\n${sep}\n${body}`;
+}
+
+function replaceMarker(content, sectionId, newBody) {
+  const re = new RegExp(
+    `(<!-- AUTO:BEGIN ${sectionId} -->)[\\s\\S]*?(<!-- AUTO:END ${sectionId} -->)`,
+    "m",
+  );
+  if (!re.test(content)) {
+    process.stderr.write(`harness-sync: marker '${sectionId}' not found in HARNESS.md\n`);
+    return content;
+  }
+  return content.replace(re, `$1\n${newBody}\n$2`);
+}
+
+// ---------- plugin discovery ----------
+
+function enumeratePluginKeys(settings) {
+  const result = [];
+  for (const [key, enabled] of Object.entries(settings.enabledPlugins ?? {})) {
+    const at = key.lastIndexOf("@");
+    if (at < 0) continue;
+    result.push({ key, plugin: key.slice(0, at), marketplace: key.slice(at + 1), enabled: !!enabled });
+  }
+  return result.sort((a, b) =>
+    a.marketplace === b.marketplace ? a.plugin.localeCompare(b.plugin) : a.marketplace.localeCompare(b.marketplace),
+  );
+}
+
+function loadMarketplaceManifests() {
+  const out = {};
+  for (const name of lsDirs(MARKETPLACES_DIR)) {
+    const manifest = readJsonSafe(join(MARKETPLACES_DIR, name, ".claude-plugin", "marketplace.json"));
+    if (manifest) out[name] = manifest;
+  }
+  return out;
+}
+
+function findPluginDir(marketplace, plugin) {
+  const parent = join(PLUGIN_CACHE, marketplace, plugin);
+  return pickLatestVersionDir(parent);
+}
+
+// Find a skill directory inside the plugin: look at a small set of conventional paths.
+function findSkillRoots(pluginDir) {
+  const candidates = [
+    join(pluginDir, "skills"),
+    join(pluginDir, ".claude", "skills"),
+    join(pluginDir, "src", "skills"),
+  ];
+  // ui-ux-pro-max nests under src/<plugin-name>/<...> with skill files at any depth;
+  // we treat its top SKILL.md (if present) as a single skill via a separate path scan.
+  return candidates.filter((p) => existsSync(p));
+}
+
+function collectSkillsFromRoot(skillsRoot) {
+  const out = [];
+  for (const dir of lsDirs(skillsRoot)) {
+    const skillMd = join(skillsRoot, dir, "SKILL.md");
+    const content = readTextSafe(skillMd);
+    if (!content) continue;
+    const fm = parseFrontmatter(content);
+    out.push({ name: fm.name || dir, description: fm.description || "" });
+  }
+  return out;
+}
+
+function collectPluginSkills(pluginDir) {
+  const roots = findSkillRoots(pluginDir);
+  const found = [];
+  for (const r of roots) found.push(...collectSkillsFromRoot(r));
+  return found;
+}
+
+function collectPluginAgents(pluginDir) {
+  const dir = join(pluginDir, "agents");
+  if (!existsSync(dir)) return [];
+  const out = [];
+  for (const file of lsFiles(dir)) {
+    if (!file.endsWith(".md")) continue;
+    const content = readTextSafe(join(dir, file));
+    if (!content) continue;
+    const fm = parseFrontmatter(content);
+    out.push({ name: fm.name || file.replace(/\.md$/, ""), description: fm.description || "" });
+  }
+  return out;
+}
+
+function collectPluginCommands(pluginDir) {
+  const dir = join(pluginDir, "commands");
+  if (!existsSync(dir)) return [];
+  const out = [];
+  for (const file of lsFiles(dir)) {
+    if (!file.endsWith(".md")) continue;
+    const content = readTextSafe(join(dir, file));
+    if (!content) continue;
+    const fm = parseFrontmatter(content);
+    out.push({ name: file.replace(/\.md$/, ""), description: fm.description || "" });
+  }
+  return out;
+}
+
+function collectPluginMcps(pluginDir) {
+  const cfg = readJsonSafe(join(pluginDir, ".mcp.json"));
+  if (!cfg) return [];
+  const servers = cfg.mcpServers && typeof cfg.mcpServers === "object" ? cfg.mcpServers : cfg;
+  return Object.entries(servers).map(([name, def]) => ({
+    name,
+    command: def?.command ? `${def.command} ${(def.args ?? []).join(" ")}`.trim() : "",
+  }));
+}
+
+function collectPluginHooks(pluginDir) {
+  const cfg = readJsonSafe(join(pluginDir, "hooks", "hooks.json"));
+  if (!cfg || !cfg.hooks || typeof cfg.hooks !== "object") return [];
+  const out = [];
+  for (const [event, groups] of Object.entries(cfg.hooks)) {
+    if (!Array.isArray(groups)) continue;
+    for (const g of groups) {
+      for (const h of g.hooks ?? []) {
+        out.push({ event, command: h.command ?? "", type: h.type ?? "" });
+      }
+    }
+  }
+  return out;
+}
+
+function loadPluginManifest(pluginDir) {
+  return readJsonSafe(join(pluginDir, ".claude-plugin", "plugin.json")) ?? {};
+}
+
+function descriptionFromMarketplace(manifests, marketplace, plugin) {
+  const m = manifests[marketplace];
+  if (!m || !Array.isArray(m.plugins)) return "";
+  const entry = m.plugins.find((p) => p.name === plugin);
+  return entry?.description ?? "";
+}
+
+// ---------- section renderers ----------
+
+function renderModel(settings) {
+  const rows = [
+    ["모델", `\`${settings.model ?? ""}\``],
+    ["Effort Level", `\`${settings.effortLevel ?? ""}\``],
+    ["Auto Updates", `\`${settings.autoUpdatesChannel ?? ""}\``],
+    ["Plans Directory", `\`${settings.plansDirectory ?? ""}\``],
+  ];
+  return renderTable(["항목", "값"], rows);
+}
+
+function renderMarketplaces(settings, manifests) {
+  const rows = [];
+  const seen = new Set();
+  for (const name of Object.keys(manifests)) {
+    seen.add(name);
+    const extra = settings.extraKnownMarketplaces?.[name];
+    const source = extra?.source
+      ? `${extra.source.source}:${extra.source.repo ?? extra.source.url ?? ""}`
+      : "official";
+    rows.push([name, source, manifests[name]?.description ?? ""]);
+  }
+  for (const [name, def] of Object.entries(settings.extraKnownMarketplaces ?? {})) {
+    if (seen.has(name)) continue;
+    const source = def.source ? `${def.source.source}:${def.source.repo ?? def.source.url ?? ""}` : "";
+    rows.push([name, source, ""]);
+  }
+  return renderTable(["마켓플레이스", "출처", "설명"], rows);
+}
+
+function renderPlugins(pluginEntries, pluginData) {
+  const byMarket = new Map();
+  for (const e of pluginEntries) {
+    if (!byMarket.has(e.marketplace)) byMarket.set(e.marketplace, []);
+    byMarket.get(e.marketplace).push(e);
+  }
+  const parts = [];
+  for (const [market, entries] of byMarket) {
+    parts.push(`#### \`${market}\``);
+    const rows = entries.map((e) => {
+      const data = pluginData.get(e.key);
+      const status = e.enabled ? "✅" : "❌";
+      const version = data?.manifest?.version ?? "";
+      const desc = data?.manifest?.description ?? data?.marketplaceDescription ?? "";
+      const note = data?.pluginDir ? "" : "(metadata unavailable)";
+      return [e.plugin, status, version, [desc, note].filter(Boolean).join(" ")];
+    });
+    parts.push(renderTable(["플러그인", "상태", "버전", "설명"], rows));
+    parts.push("");
+  }
+  return parts.join("\n");
+}
+
+function renderPluginContent(pluginEntries, pluginData, collectorKey, headers) {
+  const parts = [];
+  for (const e of pluginEntries) {
+    if (!e.enabled) continue;
+    const data = pluginData.get(e.key);
+    const items = data?.[collectorKey] ?? [];
+    if (items.length === 0) continue;
+    parts.push(`#### \`${e.plugin}\` (${e.marketplace})`);
+    const rows = items.map((it) => headers.map((h) => it[h.key] ?? ""));
+    parts.push(renderTable(headers.map((h) => h.label), rows));
+    parts.push("");
+  }
+  return parts.length > 0 ? parts.join("\n") : "_(none)_";
+}
+
+function renderCustomSkills() {
+  const skillsDir = join(REPO_ROOT, "skills");
+  const rows = [];
+  for (const dir of lsDirs(skillsDir)) {
+    const content = readTextSafe(join(skillsDir, dir, "SKILL.md"));
+    if (!content) continue;
+    const fm = parseFrontmatter(content);
+    rows.push([fm.name || dir, fm.description || ""]);
+  }
+  rows.sort((a, b) => a[0].localeCompare(b[0]));
+  return renderTable(["스킬", "설명"], rows);
+}
+
+function renderHooks(settings, pluginEntries, pluginData) {
+  const rows = [];
+  for (const [event, groups] of Object.entries(settings.hooks ?? {})) {
+    if (!Array.isArray(groups)) continue;
+    for (const g of groups) {
+      for (const h of g.hooks ?? []) {
+        rows.push([event, h.type ?? "", `\`${h.command ?? ""}\``, h.async ? "async" : "sync", "settings.json"]);
+      }
+    }
+  }
+  for (const e of pluginEntries) {
+    if (!e.enabled) continue;
+    const data = pluginData.get(e.key);
+    for (const h of data?.hooks ?? []) {
+      rows.push([h.event, h.type, `\`${h.command}\``, "", `${e.plugin}`]);
+    }
+  }
+  return renderTable(["이벤트", "타입", "명령", "모드", "출처"], rows);
+}
+
+function renderPermissions(settings) {
+  const allow = (settings.permissions?.allow ?? []).map((p) => [`\`${p}\``]);
+  const deny = (settings.permissions?.deny ?? []).map((p) => [`\`${p}\``]);
+  return [
+    "**허용 (Allow)**",
+    "",
+    renderTable(["패턴"], allow),
+    "",
+    "**거부 (Deny)**",
+    "",
+    renderTable(["패턴"], deny),
+  ].join("\n");
+}
+
+function renderGlobalInstructions() {
+  const content = readTextSafe(GLOBAL_CLAUDE_MD);
+  if (!content) return "_(no global CLAUDE.md found)_";
+  return ["```markdown", content.trimEnd(), "```"].join("\n");
+}
+
+// ---------- main ----------
+
+function main() {
+  const settings = readJsonSafe(SETTINGS_PATH);
+  if (!settings) {
+    process.stderr.write(`harness-sync: cannot read ${SETTINGS_PATH}\n`);
+    return;
+  }
+  let harness = readTextSafe(HARNESS_PATH);
+  if (!harness) {
+    process.stderr.write(`harness-sync: cannot read ${HARNESS_PATH}\n`);
+    return;
+  }
+
+  const manifests = loadMarketplaceManifests();
+  const pluginEntries = enumeratePluginKeys(settings);
+  const pluginData = new Map();
+  for (const e of pluginEntries) {
+    const pluginDir = findPluginDir(e.marketplace, e.plugin);
+    const data = {
+      pluginDir,
+      manifest: pluginDir ? loadPluginManifest(pluginDir) : null,
+      marketplaceDescription: descriptionFromMarketplace(manifests, e.marketplace, e.plugin),
+      skills: pluginDir ? collectPluginSkills(pluginDir) : [],
+      agents: pluginDir ? collectPluginAgents(pluginDir) : [],
+      commands: pluginDir ? collectPluginCommands(pluginDir) : [],
+      mcps: pluginDir ? collectPluginMcps(pluginDir) : [],
+      hooks: pluginDir ? collectPluginHooks(pluginDir) : [],
+    };
+    pluginData.set(e.key, data);
+  }
+
+  const sections = {
+    model: renderModel(settings),
+    marketplaces: renderMarketplaces(settings, manifests),
+    plugins: renderPlugins(pluginEntries, pluginData),
+    "custom-skills": renderCustomSkills(),
+    "plugin-skills": renderPluginContent(pluginEntries, pluginData, "skills", [
+      { key: "name", label: "스킬" },
+      { key: "description", label: "설명" },
+    ]),
+    "plugin-commands": renderPluginContent(pluginEntries, pluginData, "commands", [
+      { key: "name", label: "명령" },
+      { key: "description", label: "설명" },
+    ]),
+    "plugin-agents": renderPluginContent(pluginEntries, pluginData, "agents", [
+      { key: "name", label: "에이전트" },
+      { key: "description", label: "설명" },
+    ]),
+    "plugin-mcps": renderPluginContent(pluginEntries, pluginData, "mcps", [
+      { key: "name", label: "MCP 서버" },
+      { key: "command", label: "실행 명령" },
+    ]),
+    hooks: renderHooks(settings, pluginEntries, pluginData),
+    permissions: renderPermissions(settings),
+    "global-instructions": renderGlobalInstructions(),
+  };
+
+  let next = harness;
+  for (const [id, body] of Object.entries(sections)) {
+    next = replaceMarker(next, id, body);
+  }
+
+  if (next !== harness) {
+    writeFileSync(HARNESS_PATH, next, "utf8");
+  }
+}
+
+try {
+  main();
+} catch (err) {
+  process.stderr.write(`harness-sync: ${err?.stack ?? err}\n`);
+}
