{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(grep *)",
      "Bash(Get-ChildItem *)",
      "mcp__plugin_playwright",
      "Bash(xargs grep *)",
      "mcp__plugin_chrome-devtools",
      "mcp__plugin_context7",
      "mcp__context7",
      "mcp__aws-knowledge",
      "mcp__plugin_playwright_playwright__browser_console_messages",
      "mcp__plugin_playwright_playwright__browser_close",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__evaluate_script",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_snapshot",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__click"
    ],
    "deny": [
      "Write(./node_modules/**)"
    ],
    "ask": [
      "Write(./.env)",
      "Bash(* deploy *)",
      "Bash(* publish *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(pnpm add *)",
      "Bash(npm install *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$DOTCLAUDE_DIR/scripts/harness-sync/harness-sync.mjs\"",
            "async": false
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$DOTCLAUDE_DIR/scripts/hooks/notify.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs npx prettier --write"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "document-skills@anthropic-agent-skills": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "slack@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "claude-code-toolkit": {
      "source": {
        "source": "github",
        "repo": "spences10/claude-code-toolkit"
      }
    }
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "plansDirectory": ".claude/plans",
  "skipAutoPermissionPrompt": true
}
